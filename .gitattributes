# Files excluded from `git archive` output (release tarballs).
# Keeps the published artifact lean — CI scaffolding and editor configs
# are not useful to end users installing from a release tarball.
.github/         export-ignore
.gitattributes   export-ignore
.gitignore       export-ignore
.vscode/         export-ignore
.idea/           export-ignore
.remember/       export-ignore
.claude/         export-ignore
